# DeepSeek Infra 环境变量模板：复制为 .env 后按需填写。
# .env 含密钥，已被 .gitignore / 发布脚本排除，不要提交。
# 完整变量清单与默认值见 README「环境变量」一节。

# ---- 上游凭证 ----------------------------------------------------------------
# DeepSeek API Key（也可留空，改在页面设置里临时填写）
DEEPSEEK_API_KEY=
# Tavily 搜索 API Key（可选，联网搜索用）
TAVILY_API_KEY=

# ---- 服务绑定 ----------------------------------------------------------------
# 容器 / 局域网部署用 0.0.0.0；本机开发保持 127.0.0.1
HOST=0.0.0.0
PORT=8000

# ---- 本地鉴权 ----------------------------------------------------------------
# 1 = 关闭本地 token 鉴权（仅可信开发环境）；生产保持 0
AUTH_DISABLED=0
# 固定本地访问 token（留空则自动生成并写入 <数据目录>/.auth-token）
AUTH_TOKEN=
# 追加允许的 Host 头（反向代理域名等），逗号分隔
#AUTH_ALLOWED_HOSTS=

# ---- 预算与超时 --------------------------------------------------------------
# 多 Agent 单次运行 token 预算（0 = 不限制）
MULTI_AGENT_TOKEN_BUDGET=2000000
#DEEPSEEK_TIMEOUT_SECONDS=180
#MULTI_AGENT_TIMEOUT_SECONDS=3900

# ---- 可选能力开关（默认值见 README，按需取消注释） ----------------------------
# 本地 Ollama provider（/v1 暴露 ollama/<tag>）
#OLLAMA_ENABLED=1
#OLLAMA_BASE_URL=http://127.0.0.1:11434
# 端侧 GGUF 推理
#EDGE_INFERENCE_ENABLED=1
#EDGE_MODEL_PATH=/models/your-model.gguf
# MCP Tool Hub 能力画像（full / researcher / coder / ...）
#MCP_CAPABILITY=full
# A2A Agent Mesh 默认执行角色
#A2A_DEFAULT_AGENT=reasoner
# 请求调度层限流（默认 0 = 不限流）
#SCHEDULER_RATE_PER_SECOND=0
# Context Taint 防火墙与工具策略均默认开启：
#TAINT_ENABLED=1
#TOOL_POLICY_ENABLED=1
